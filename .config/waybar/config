{
  "layer": "top",
  "position": "bottom",
  "height": 30,
  "spacing": 4,
  "modules-left": ["wlr/workspaces", "custom/media", "custom/recorder"],
  "modules-center": ["hyprland/window"],
  "modules-right": [
    "backlight",
    "pulseaudio",
    "network",
    "cpu",
    "memory",
    "temperature",
    "hyprland/language",
    "battery",
    "clock",
  ],
  "custom/recorder": {
    "exec-if": "pgrep wf-recorder",
    "exec": "pgrep wf-recorder",
    "on-click": "killall -SIGINT wf-recorder",
    "interval": 1,
    "format": "[ STOP ]"
  },
  "hyprland/language": {
    "format": "[ {} яДЬ ]"
  },
  "wlr/workspaces": {
    "format": "<big>{icon}</big>",
    "on-click": "activate",
    "format-icons": {
      "1": "яДа",
      "2": "яЙи",
      "3": "яиА",
      "4": "яАБ",
      "5": "яДб",
      "6": "яно",
      "urgent": "яБк",
      "default": "яДС"
    }
  },
  "clock": {
    "format": "[ {:%H:%M} ]",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "format-alt": "[ {:%Y-%m-%d} ]"
  },
  "cpu": {
    "format": "[ {usage}% яЛЫ ]",
    "tooltip": false
  },
  "memory": {
    "format": "[ {}% яФ╕ ]"
  },
  "backlight": {
    "device": "amdgpu_bl0",
    "format": "[ {percent}% {icon} ]",
    "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"],
    "on-scroll-up": "light -A 1",
    "on-scroll-down": "light -U 1",
    "smooth-scrolling-threshold": 3
  },
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "[ {capacity}% {icon} ]",
    "format-charging": "[ {capacity}% яЧз ]",
    "format-plugged": "[ {capacity}% яЗж ]",
    "format-alt": "[ {time} {icon} ]",
    "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
  },
  "network": {
    "format-wifi": "[ ({signalStrength}%) яЗл ]",
    "format-ethernet": "[ {ipaddr}/{cidr} яЮЦ ]",
    "tooltip-format": "{ifname} via {gwaddr} яЮЦ",
    "format-linked": "[ {ifname} (No IP) яЮЦ ]",
    "format-disconnected": "[ Disconnected тЪа ]",
    "format-alt": "[ {ifname}: {ipaddr}/{cidr} ]"
  },
  "pulseaudio": {
    "smooth-scrolling-threshold": 3,
    "format": "[ {volume}% {icon} {format_source} ]",
    "format-bluetooth": "[ {volume}% {icon}яКФ {format_source} ]",
    "format-bluetooth-muted": "[ яЪй {icon}яКФ {format_source} ]",
    "format-muted": "яЪй {format_source}",
    "format-source": "{volume}% яД░",
    "format-source-muted": "яД▒",
    "format-icons": {
      "headphone": "яАе",
      "hands-free": "яЦР",
      "headset": "яЦР",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": ["яАж", "яАз", "яАи"]
    },
    "on-click": "pavucontrol"
  },
  "custom/media": {
    "format": "{icon} {}",
    "return-type": "json",
    "max-length": 40,
    "format-icons": {
      "spotify": "яЖ╝",
      "default": "ЁЯОЬ"
    },
    "escape": true,
    "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
  }
}
